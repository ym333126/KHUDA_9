        "FEATURE_COLS = [\n",
        "    \"danceability\", \"energy\", \"key\", \"loudness\", \"mode\",\n",
        "    \"speechiness\", \"acoustics\", \"instrumentalness\", \"liveliness\",\n",
        "    \"valence\", \"tempo\", \"duration_ms\", \"time_signature\",\n",
        "    \"Genre_new\", \"Explicit\"\n",
        "]\n",
        "\n",
        "LABEL_COLS = [\"comeback_label\", \"gain_rank\", \"late_hit_ratio\", \"comeback_score\", \"comeback_score_pos\"]\n",
        "\n",
        "# =========================\n",
        "# 1) audio 컬럼명 통일 + Global 필터\n",
        "# =========================\n",
        "audio_feat = audio.copy()\n",
        "\n",
        "audio_feat = audio_feat.rename(columns={\n",
        "    \"Uri\": \"uri\",\n",
        "    \"Title\": \"title_audio\",\n",
        "    \"Artist\": \"artist_audio\",\n",
        "    \"Release_date\": \"release_date\"\n",
        "})\n",
        "\n",
        "audio_feat[\"release_date\"] = pd.to_datetime(audio_feat[\"release_date\"], errors=\"coerce\")\n",
        "audio_feat = audio_feat[audio_feat[\"Country\"].astype(str).str.lower().eq(\"global\")].copy()\n",
        "\n",
        "# =========================\n",
        "# 2) song_id 생성 (album/single 중복 통합)\n",
        "# =========================\n",
        "def norm_basic(s: pd.Series) -> pd.Series:\n",
        "    s = s.fillna(\"\").astype(str).str.lower().str.strip()\n",
        "    s = s.str.replace(r\"\\s+\", \" \", regex=True)\n",
        "    s = s.str.replace(r\"[’‘]\", \"'\", regex=True)\n",
        "    s = s.str.replace(r\"[‐-–—]\", \"-\", regex=True)\n",
        "    return s\n",
        "\n",
        "audio_feat[\"title_norm\"]  = norm_basic(audio_feat[\"title_audio\"])\n",
        "audio_feat[\"artist_norm\"] = norm_basic(audio_feat[\"artist_audio\"])\n",
        "audio_feat[\"song_id\"] = audio_feat[\"title_norm\"] + \"___\" + audio_feat[\"artist_norm\"]\n",
        "\n",
        "# =========================\n",
        "# 3) song_id별 대표 row 선택 (가장 이른 release_date)\n",
        "# =========================\n",
        "audio_rep = (\n",
        "    audio_feat.sort_values(\"release_date\")\n",
        "              .groupby(\"song_id\", as_index=False)\n",
        "              .first()\n",
        ")\n",
        "\n",
        "# =========================\n",
        "# 4) 필요한 피처 컬럼 존재 확인 + 타입 정리\n",
        "# =========================\n",
        "missing = [c for c in FEATURE_COLS if c not in audio_rep.columns]\n",
        "if missing:\n",
        "    print(\"⚠️ audio_rep에 없는 FEATURE_COLS:\", missing)\n",
        "\n",
        "use_cols = [c for c in FEATURE_COLS if c in audio_rep.columns]\n",
        "\n",
        "# 숫자형 변환\n",
        "for c in use_cols:\n",
        "    if c not in [\"Genre_new\"]:\n",
        "        audio_rep[c] = pd.to_numeric(audio_rep[c], errors=\"coerce\")\n",
        "\n",
        "# Explicit이 True/False거나 문자열이면 0/1로 정리(선택)\n",
        "if \"Explicit\" in audio_rep.columns:\n",
        "    if audio_rep[\"Explicit\"].dtype == \"bool\":\n",
        "        audio_rep[\"Explicit\"] = audio_rep[\"Explicit\"].astype(int)\n",
        "    else:\n",
        "        # \"true\"/\"false\", \"True\"/\"False\", 0/1 등 섞여도 처리\n",
        "        audio_rep[\"Explicit\"] = audio_rep[\"Explicit\"].astype(str).str.lower().map({\"true\":1, \"false\":0}).fillna(pd.to_numeric(audio_rep[\"Explicit\"], errors=\"coerce\"))\n",
        "\n",
        "# =========================\n",
        "# 5) 라벨 붙여서 final 만들기\n",
        "# =========================\n",
        "final = (\n",
        "    audio_rep[[\"song_id\"] + use_cols]\n",
        "    .merge(songs[[\"song_id\"] + LABEL_COLS], on=\"song_id\", how=\"inner\")\n",
        ")\n",
        "\n",
        "print(\"final rows:\", len(final))\n",
        "print(\"label rate:\", final[\"comeback_label\"].mean())\n",
        "\n",
        "# =========================\n",
        "# 6) 모델 입력 X, y (범주형 원핫 포함)\n",
        "# =========================\n",
        "X = final[use_cols].copy()\n",
        "y = final[\"comeback_label\"].copy()\n",
        "\n",
        "cat_cols = X.select_dtypes(include=[\"object\"]).columns.tolist()\n",
        "X_encoded = pd.get_dummies(X, columns=cat_cols, dummy_na=True)\n",
        "\n",
        "print(\"X_encoded shape:\", X_encoded.shape, \"y shape:\", y.shape)"
