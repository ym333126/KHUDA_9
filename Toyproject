      "cell_type": "code",
      "source": [
        "# ----------------------------\n",
        "# Logistic Regression (balanced) + SMOTE 적용\n",
        "# ----------------------------\n",
        "logreg_smote = Pipeline([\n",
        "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
        "    (\"scaler\", StandardScaler(with_mean=False)),\n",
        "    (\"smote\", SMOTE(random_state=42, k_neighbors=3, sampling_strategy=0.4)),\n",
        "    (\"clf\", LogisticRegression(max_iter=3000))\n",
        "])\n",
        "\n",
        "logreg_smote.fit(X_train, y_train)\n",
        "p_lr = logreg_smote.predict_proba(X_test)[:, 1]\n",
        "\n",
        "print(\"=== Before SMOTE ===\")\n",
        "\n",
        "print(\"Train label count:\")\n",
        "print(pd.Series(y_train).value_counts())\n",
        "print(\"Train positive rate:\", round(pd.Series(y_train).mean(), 4))\n",
        "\n",
        "print(\"\\nTest label count:\")\n",
        "print(pd.Series(y_test).value_counts())\n",
        "print(\"Test positive rate:\", round(pd.Series(y_test).mean(), 4))\n",
        "\n",
        "sm = SMOTE(random_state=42, k_neighbors=3, sampling_strategy=0.4)\n",
        "X_train_sm, y_train_sm = sm.fit_resample(X_train, y_train)\n",
        "\n",
        "print(\"\\n=== After SMOTE (Train only) ===\")\n",
        "print(pd.Series(y_train_sm).value_counts())\n",
        "print(\"Train positive rate:\", round(pd.Series(y_train_sm).mean(), 4))\n",
        "\n",
        "\n",
        "print(\"=== Logistic Regression ===\")\n",
        "print(\"PR-AUC(AP):\", round(average_precision_score(y_test, p_lr), 4))\n",
        "print(\"ROC-AUC   :\", round(roc_auc_score(y_test, p_lr), 4))\n",
        "\n",
        "\n",
        "yhat_lr = (p_lr >= 0.3).astype(int)\n",
        "print(classification_report(y_test, yhat_lr, digits=4))\n",
        "\n",
        "\n",
        "# 로지스틱 중요도(절대값 큰 coef)\n",
