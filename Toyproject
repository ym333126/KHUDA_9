        "THRESHOLD = 0.30\n",
        "\n",
        "def _normalize_cols(df):\n",
        "    df = df.copy()\n",
        "    df.columns = [re.sub(r\"__+\", \"_\", str(c).strip().replace(\" \", \"_\")) for c in df.columns]\n",
        "    return df\n",
        "\n",
        "def _smart_bool_to_int(s):\n",
        "    x = s.astype(str).str.lower().str.strip()\n",
        "    out = x.map({\"true\": 1, \"false\": 0, \"t\": 1, \"f\": 0, \"yes\": 1, \"no\": 0})\n",
        "    out = out.fillna(pd.to_numeric(s, errors=\"coerce\"))\n",
        "    return out.fillna(0).astype(int)\n",
        "\n",
        "# ---------------------------\n",
        "# 1) 데이터 로드\n",
        "# ---------------------------\n",
        "chart22 = pd.read_csv(TOPCHART_2022_CSV)\n",
        "chart22 = _normalize_cols(chart22)\n",
        "\n",
        "# ---------------------------\n",
        "# 2) 누수 컬럼 제거\n",
        "# ---------------------------\n",
        "leaky_cols = [\n",
        "    \"peak_rank\",\"peak_position\",\"best_position\",\n",
        "    \"weeks_on_chart\",\"weeks\",\"week\",\n",
        "    \"chart_position\",\"position\",\"rank\",\n",
        "    \"streams\",\"stream\",\"spotify_streams\",\n",
        "    \"last_week\",\"movement\",\"change\",\"delta\"\n",
        "]\n",
        "chart22_pred = chart22.drop(columns=[c for c in leaky_cols if c in chart22.columns], errors=\"ignore\")\n",
        "\n",
        "# ---------------------------\n",
        "# 3) ID / 텍스트 컬럼 제거 (예측 피처용)\n",
        "# ---------------------------\n",
        "id_text_cols = [\n",
        "    \"track_name\",\"track\",\"song\",\"title\",\"name\",\n",
        "    \"artist_name\",\"artist\",\"artists\",\n",
        "    \"uri\",\"track_uri\",\"spotify_uri\",\"id\",\"track_id\",\n",
        "    \"isrc\",\"album\",\"album_name\"\n",
        "]\n",
        "chart22_pred = chart22_pred.drop(\n",
        "    columns=[c for c in id_text_cols if c in chart22_pred.columns],\n",
        "    errors=\"ignore\"\n",
        ")\n",
        "\n",
        "# ---------------------------\n",
        "# 4) Explicit / 컬럼명 정리\n",
        "# ---------------------------\n",
        "if \"explicit\" in chart22_pred.columns and \"Explicit\" not in chart22_pred.columns:\n",
        "    chart22_pred[\"Explicit\"] = _smart_bool_to_int(chart22_pred[\"explicit\"])\n",
        "    chart22_pred = chart22_pred.drop(columns=[\"explicit\"])\n",
        "elif \"Explicit\" in chart22_pred.columns:\n",
        "    chart22_pred[\"Explicit\"] = _smart_bool_to_int(chart22_pred[\"Explicit\"])\n",
        "\n",
        "# 학습 컬럼 기준으로 이름 맞추기\n",
        "train_cols = set(X_encoded.columns)\n",
        "rename_map = {}\n",
        "if \"acousticness\" in chart22_pred.columns and \"acoustics\" in train_cols:\n",
        "    rename_map[\"acousticness\"] = \"acoustics\"\n",
        "if \"liveness\" in chart22_pred.columns and \"liveliness\" in train_cols:\n",
        "    rename_map[\"liveness\"] = \"liveliness\"\n",
        "chart22_pred = chart22_pred.rename(columns=rename_map)\n",
        "\n",
        "# ---------------------------\n",
        "# 5) 원핫 + 컬럼 정렬\n",
        "# ---------------------------\n",
        "cat_cols = chart22_pred.select_dtypes(include=[\"object\"]).columns.tolist()\n",
        "X22_enc = pd.get_dummies(chart22_pred, columns=cat_cols, dummy_na=True)\n",
        "\n",
        "X22_enc = X22_enc.reindex(columns=X_encoded.columns, fill_value=0)\n",
        "\n",
        "# ---------------------------\n",
        "# 6) 예측\n",
        "# ---------------------------\n",
        "comeback_proba = best_model.predict_proba(X22_enc)[:, 1]\n",
        "comeback_pred = (comeback_proba >= THRESHOLD).astype(int)\n",
        "\n",
        "# ---------------------------\n",
        "# 7) 결과 정리 (track_name / artist_name 분리)\n",
        "# ---------------------------\n",
        "out = pd.DataFrame({\n",
        "    \"track_name\": chart22[\"track_name\"].astype(str),\n",
        "    \"artist_name\": chart22[\"artist_names\"].astype(str),\n",
        "    \"comeback_proba\": comeback_proba,\n",
        "    \"comeback_pred\": comeback_pred\n",
        "})\n",
