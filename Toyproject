    {
      "cell_type": "code",
      "source": [
        "# LightGBM\n",
        "import numpy as np\n",
        "import lightgbm as lgb\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.impute import SimpleImputer\n",
        "from sklearn.metrics import roc_auc_score, average_precision_score, classification_report, precision_recall_curve\n",
        "from imblearn.pipeline import Pipeline\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ----------------------------\n",
        "# 0) split\n",
        "# ----------------------------\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X_encoded, y.astype(int),\n",
        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=y\n",
        ")\n",
        "\n",
        "# ----------------------------\n",
        "# 1) 불균형 가중치 계산 (neg/pos 비율)\n",
        "# ----------------------------\n",
        "pos = int(np.sum(y_train))\n",
        "neg = int(len(y_train) - pos)\n",
        "scale_pos_weight = neg / max(pos, 1)\n",
        "print(\"pos:\", pos, \"neg:\", neg, \"scale_pos_weight:\", round(scale_pos_weight, 3))\n",
        "\n",
        "# ----------------------------\n",
        "# 2) LightGBM 파이프라인\n",
        "# ----------------------------\n",
        "lgbm_nosmote = Pipeline([\n",
        "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
        "    (\"clf\", lgb.LGBMClassifier(\n",
        "        objective=\"binary\",\n",
        "        n_estimators=1200,\n",
        "        learning_rate=0.03,\n",
        "        num_leaves=63,\n",
        "        max_depth=-1,\n",
        "        min_child_samples=50,\n",
        "        subsample=0.9,\n",
        "        colsample_bytree=0.9,\n",
        "        random_state=42,\n",
        "\n",
        "        # 핵심: 불균형 처리\n",
        "        scale_pos_weight=scale_pos_weight,\n",
        "        # 대안: is_unbalance=True  # scale_pos_weight 대신 이걸 써도 됨(둘 중 하나만)\n",
        "    ))\n",
        "])\n",
        "\n",
        "# ----------------------------\n",
        "# 3) 학습 & 예측\n",
        "# ----------------------------\n",
        "lgbm_nosmote.fit(X_train, y_train)\n",
        "p_lgb = lgbm_nosmote.predict_proba(X_test)[:, 1]\n",
        "\n",
        "print(\"=== LightGBM (NO SMOTE) ===\")\n",
        "print(\"ROC-AUC:\", round(roc_auc_score(y_test, p_lgb), 4))\n",
        "print(\"PR-AUC :\", round(average_precision_score(y_test, p_lgb), 4))\n",
        "print(classification_report(y_test, (p_lgb >= 0.5).astype(int), digits=4))"
