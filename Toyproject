          ]
        }
      ],
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "chart = pd.read_csv(\"chart.csv\", encoding='utf-8')\n",
        "audio = pd.read_csv(\"audio.csv\", encoding='utf-8')\n",
        "\n",
        "# =========================\n",
        "# 0) 파라미터\n",
        "# =========================\n",
        "EARLY_DAYS = 60\n",
        "EARLY_TOP = 100\n",
        "EARLY_MAX_HIT_DAYS = 3\n",
        "\n",
        "LATE_START = 180\n",
        "LATE_TOP = 50\n",
        "LATE_MIN_HIT_DAYS = 3\n",
        "\n",
        "OUT_RANK = 201\n",
        "\n",
        "# =========================\n",
        "# 1) copy + 타입 변환 + Global 필터\n",
        "# =========================\n",
        "chart2 = chart.copy()\n",
        "audio2 = audio.copy()\n",
        "\n",
        "# chart\n",
        "chart2[\"date\"] = pd.to_datetime(chart2[\"date\"], errors=\"coerce\", dayfirst=True)\n",
        "chart2[\"position\"] = pd.to_numeric(chart2[\"position\"], errors=\"coerce\")\n",
        "chart2 = chart2.dropna(subset=[\"uri\", \"date\", \"position\"])\n",
        "\n",
        "# Global만 (chart의 country)\n",
        "chart2 = chart2[chart2[\"country\"].astype(str).str.lower().eq(\"global\")].copy()\n",
        "\n",
        "# audio: 필수 컬럼명 통일(대소문 차이 처리)\n",
        "audio2 = audio2.rename(columns={\n",
        "    \"Uri\": \"uri\",\n",
        "    \"Title\": \"title_audio\",\n",
        "    \"Artist\": \"artist_audio\",\n",
        "    \"Release_date\": \"release_date\"\n",
        "})\n",
        "\n",
        "# audio 타입 변환\n",
        "audio2[\"release_date\"] = pd.to_datetime(audio2[\"release_date\"], errors=\"coerce\")\n",
        "audio2 = audio2.dropna(subset=[\"uri\", \"title_audio\", \"artist_audio\", \"release_date\"])\n",
        "\n",
        "# Global만 (audio의 Country)\n",
        "audio2 = audio2[audio2[\"Country\"].astype(str).str.lower().eq(\"global\")].copy()\n",
        "\n",
        "# =========================\n",
        "# 2) INNER JOIN (uri)\n",
        "# =========================\n",
        "merged = chart2.merge(audio2, on=\"uri\", how=\"inner\")\n",
        "\n",
        "print(\"chart rows:\", len(chart2))\n",
        "print(\"audio rows:\", len(audio2))\n",
        "print(\"merged rows:\", len(merged))\n",
        "print(\"unique uris in merged:\", merged[\"uri\"].nunique())"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# =========================\n",
        "# 3) song_id 생성 (album/single 중복 통합)\n",
        "# ※ remix는 다른 곡이므로 title 괄호/버전표기를 삭제하지 않음\n",
        "# =========================\n",
        "def norm_basic(s: pd.Series) -> pd.Series:\n",
        "    s = s.fillna(\"\").astype(str).str.lower().str.strip()\n",
        "    s = s.str.replace(r\"\\s+\", \" \", regex=True)\n",
        "    s = s.str.replace(r\"[’‘]\", \"'\", regex=True)\n",
        "    s = s.str.replace(r\"[‐-–—]\", \"-\", regex=True)\n",
        "    return s\n",
        "\n",
        "merged[\"title_norm\"]  = norm_basic(merged[\"title_audio\"])\n",
        "merged[\"artist_norm\"] = norm_basic(merged[\"artist_audio\"])\n",
        "merged[\"song_id\"] = merged[\"title_norm\"] + \"___\" + merged[\"artist_norm\"]\n",
        "\n",
        "# song_id 기준 \"곡 발매일\" = 가장 빠른 release_date\n",
        "song_release = (\n",
        "    merged.groupby(\"song_id\", as_index=False)[\"release_date\"]\n",
        "          .min()\n",
        "          .rename(columns={\"release_date\": \"release_date_song\"})\n",
        ")\n",
        "\n",
        "# =========================\n",
        "# 4) song-day로 접기 (같은 곡이 같은 날 여러 uri면 best rank만)\n",
        "# =========================\n",
        "song_day = (\n",
        "    merged.groupby([\"song_id\", \"date\"], as_index=False)[\"position\"]\n",
        "          .min()\n",
        "          .merge(song_release, on=\"song_id\", how=\"left\")\n",
        ")\n",
        "\n",
        "song_day[\"days_since_release\"] = (song_day[\"date\"] - song_day[\"release_date_song\"]).dt.days\n",
        "song_day = song_day[song_day[\"days_since_release\"] >= 0].copy()\n",
        "\n",
        "print(\"unique songs (song_id):\", song_day[\"song_id\"].nunique())\n",
        "print(\"song_day rows:\", len(song_day))\n",
        "\n",
        "# =========================\n",
        "# 5) 라벨링 (early/late 집계)\n",
        "# =========================\n",
        "early = song_day[song_day[\"days_since_release\"].between(0, EARLY_DAYS)]\n",
        "early_agg = early.groupby(\"song_id\").agg(\n",
        "    early_best_rank=(\"position\", \"min\"),\n",
        "    early_top_hit_days=(\"position\", lambda s: (s <= EARLY_TOP).sum()),\n",
        "    early_obs_days=(\"date\", \"nunique\")\n",
        ").reset_index()\n",
        "\n",
        "late = song_day[song_day[\"days_since_release\"] >= LATE_START]\n",
        "late_agg = late.groupby(\"song_id\").agg(\n",
        "    late_best_rank=(\"position\", \"min\"),\n",
        "    late_top_hit_days=(\"position\", lambda s: (s <= LATE_TOP).sum()),\n",
        "    late_obs_days=(\"date\", \"nunique\")\n",
        ").reset_index()\n",
        "\n",
        "songs = (\n",
        "    song_release\n",
        "    .merge(early_agg, on=\"song_id\", how=\"left\")\n",
        "    .merge(late_agg, on=\"song_id\", how=\"left\")\n",
        ")\n",
        "\n",
        "# 해당 구간 차트 미등장 처리\n",
        "songs[\"early_best_rank\"] = songs[\"early_best_rank\"].fillna(OUT_RANK)\n",
        "songs[\"early_top_hit_days\"] = songs[\"early_top_hit_days\"].fillna(0)\n",
        "\n",
        "songs[\"late_best_rank\"] = songs[\"late_best_rank\"].fillna(OUT_RANK)\n",
        "songs[\"late_top_hit_days\"] = songs[\"late_top_hit_days\"].fillna(0)\n",
        "songs[\"late_obs_days\"] = songs[\"late_obs_days\"].fillna(0)\n",
        "\n",
        "# 라벨\n",
        "songs[\"early_fail\"] = (songs[\"early_top_hit_days\"] <= EARLY_MAX_HIT_DAYS).astype(int)\n",
        "songs[\"late_success\"] = (songs[\"late_top_hit_days\"] >= LATE_MIN_HIT_DAYS).astype(int)\n",
        "songs[\"comeback_label\"] = ((songs[\"early_fail\"] == 1) & (songs[\"late_success\"] == 1)).astype(int)\n",
        "\n",
        "# =========================\n",
        "# 6) 역주행 강도 A/B/C\n",
        "# =========================\n",
        "# A) improvement magnitude\n",
        "songs[\"gain_rank\"] = songs[\"early_best_rank\"] - songs[\"late_best_rank\"]\n",
        "\n",
        "# B) persistence (days + ratio)\n",
        "songs[\"late_hit_days\"] = songs[\"late_top_hit_days\"]\n",
        "songs[\"late_hit_ratio\"] = np.where(\n",
        "    songs[\"late_obs_days\"] > 0,\n",
        "    songs[\"late_hit_days\"] / songs[\"late_obs_days\"],\n",
        "    0\n",
        ")\n",
        "\n",
        "# C) combined score\n",
        "songs[\"comeback_score\"] = songs[\"gain_rank\"] * np.log1p(songs[\"late_hit_days\"])\n",
        "songs[\"comeback_score_pos\"] = songs[\"comeback_score\"].clip(lower=0)\n",
        "\n",
        "# =========================\n",
        "# 7) 라벨 비율 출력 (네가 원하는 부분)\n",
        "# =========================\n",
        "total_songs = len(songs)\n",
        "pos_songs = int(songs[\"comeback_label\"].sum())\n",
        "rate = pos_songs / total_songs if total_songs else 0\n",
        "\n",
        "print(f\"\\n✅ Comeback label(역주행=1) 곡 수: {pos_songs} / {total_songs}  ({rate:.4%})\")\n",
        "\n",
        "# (선택) 상위 역주행 곡 20개 보기\n",
        "cols_show = [\n",
        "    \"song_id\", \"release_date_song\",\n",
        "    \"early_best_rank\", \"early_top_hit_days\",\n",
        "    \"late_best_rank\", \"late_hit_days\",\n",
        "    \"comeback_label\",\n",
        "    \"gain_rank\", \"late_hit_ratio\", \"comeback_score\"\n",
        "]\n",
        "songs.sort_values([\"comeback_label\", \"comeback_score\"], ascending=[False, False])[cols_show].head()"
      ],
